# HumbleLegend 环境变量配置文件

# 数据库配置
DATABASE_URL=sqlite:///./humblelegend.db
DATABASE_ECHO=False

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 服务器配置
API_HOST=0.0.0.0
API_PORT=8000

# 微信配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_TOKEN=your_wechat_token
WECHAT_ENCODING_AES_KEY=your_wechat_encoding_aes_key

# 飞书配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token
FEISHU_ENCRYPT_KEY=your_feishu_encrypt_key

# 图片识别配置
VOLCENGINE_ACCESS_KEY=your_volcengine_access_key
VOLCENGINE_SECRET_KEY=your_volcengine_secret_key
VOLCENGINE_REGION=cn-north-1

# 营养数据库配置
USDA_API_KEY=your_usda_api_key
USDA_API_URL=https://api.nal.usda.gov/fdc/v1

# 图表生成配置
CHART_OUTPUT_DIR=output/charts
CHART_TYPE=mermaid

# 文档导出配置
EXPORT_OUTPUT_DIR=output/exports

# 数据留存配置
DATA_RETENTION_DAYS=365
AUTO_CLEANUP=True